CONTAINER_NAME=vllm-b70-server

# Target Source Control or Image
# Pointing directly to the upstream main branch
VLLM_BUILD_CONTEXT=https://github.com/vllm-project/vllm.git#main
VLLM_DOCKERFILE=docker/Dockerfile.xpu

# Resource & Network Mapping
HOST_PORT=8000
SHM_SIZE=32g
MODEL_MOUNT_PATH=~/models/

# vLLM Execution Flags
# Replace with your specific Hugging Face repo or local path
MODEL_NAME=Qwen/Qwen3.6-35B-A3B
TP_SIZE=2
QUANT_ARG="--quantization fp8"
MAX_MODEL_LEN=65536
KV_CACHE_DTYPE=auto
EXTRA_ARGS="--reasoning-parser qwen3 --block-size 32 --max-num-seqs 512"

# Intel XPU Specific Overrides
VLLM_WORKER_MULTIPROC_METHOD=spawn
SYCL_PI_LEVEL_ZERO_USE_IMMEDIATE_COMMANDLISTS=1
VLLM_XPU_ENABLE_XPU_GRAPH=0
VLLM_XPU_USE_SAMPLER_KERNEL=1

# Use ZE_AFFINITY_MASK to explicitly bind execution to your two discrete B70 GPUs 
# and ignore any integrated graphics or unexpected display outputs.
ZE_AFFINITY_MASK=0,1

# Hugging Face Configuration
# Replace with your actual write/read token from HF
HF_TOKEN=hf_get_your_own_key_gosh_darnit
# Points the HF downloader to your persistent volume mount
HF_HOME=~/.cache/huggingface
